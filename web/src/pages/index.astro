---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLang, useTranslations } from '../i18n';

const lang = getLang(Astro.url.searchParams.get('lang') ?? undefined);
const t = useTranslations(lang);
---

<BaseLayout title="Erika Zambrano — QA Automation Portfolio" activePage="home">
  <header>
    <div class="container">
      <h1 class="header-name">Erika Zambrano</h1>
      <p class="header-role">{t('header-role')}</p>
      <nav class="header-links" aria-label="Contact links">
        <a href="https://www.linkedin.com/in/erikazambrano/" target="_blank" rel="noopener">LinkedIn</a>
        <a href="https://github.com/Erika-Zambrano" target="_blank" rel="noopener">GitHub</a>
        <a href="mailto:erikajzm@gmail.com">erikajzm@gmail.com</a>
      </nav>
    </div>
  </header>

  <section id="about">
    <div class="container">
      <p class="section-label">{t('about-label')}</p>
      <p>{t('about-text')}</p>
    </div>
  </section>

  <section id="suites">
    <div class="container">
      <p class="section-label">{t('suites-label')}</p>
      <h2 class="section-title">{t('suites-title')}</h2>
      <div class="cards">
        <div class="card">
          <div class="card-header">
            <span class="card-title">{t('card1-title')}</span>
            <div class="badges">
              <span class="badge badge-type">UI</span>
              <span class="badge badge-tag">@smoke</span>
            </div>
          </div>
          <p class="card-file">tests/ui/navigation.spec.ts</p>
        </div>
        <div class="card">
          <div class="card-header">
            <span class="card-title">{t('card2-title')}</span>
            <div class="badges">
              <span class="badge badge-type">UI</span>
              <span class="badge badge-tag">@regression</span>
            </div>
          </div>
          <p class="card-file">tests/ui/forms.spec.ts</p>
        </div>
        <div class="card">
          <div class="card-header">
            <span class="card-title">{t('card3-title')}</span>
            <div class="badges">
              <span class="badge badge-type">UI</span>
              <span class="badge badge-tag">@regression</span>
            </div>
          </div>
          <p class="card-file">tests/ui/accessibility.spec.ts</p>
        </div>
        <div class="card">
          <div class="card-header">
            <span class="card-title">{t('card4-title')}</span>
            <div class="badges">
              <span class="badge badge-type">API</span>
              <span class="badge badge-tag">@sanity</span>
            </div>
          </div>
          <p class="card-file">tests/api/public-api.spec.ts</p>
        </div>
      </div>
    </div>
  </section>

  <section id="ci">
    <div class="container">
      <p class="section-label">{t('ci-label')}</p>
      <h2 class="section-title">{t('ci-title')}</h2>
      <p class="ci-description" set:html={t('ci-desc')} />
      <div class="ci-badge-row">
        <img
          src="https://github.com/Erika-Zambrano/qa-automation-portfolio/actions/workflows/playwright.yml/badge.svg"
          alt="CI status badge"
          height="20"
        />
        <a href="https://github.com/Erika-Zambrano/qa-automation-portfolio" target="_blank" rel="noopener">
          {t('ci-link')}
        </a>
      </div>
    </div>
  </section>

  <section id="stack">
    <div class="container">
      <p class="section-label">{t('stack-label')}</p>
      <h2 class="section-title">{t('stack-title')}</h2>
      <ul class="stack-list">
        <li class="stack-item">
          <span class="stack-name">Playwright</span>
          <span class="stack-desc">{t('stack-pw')}</span>
        </li>
        <li class="stack-item">
          <span class="stack-name">TypeScript</span>
          <span class="stack-desc">{t('stack-ts')}</span>
        </li>
        <li class="stack-item">
          <span class="stack-name">GitHub Actions</span>
          <span class="stack-desc">CI/CD</span>
        </li>
        <li class="stack-item">
          <span class="stack-name">Page Object Model</span>
          <span class="stack-desc">{t('stack-pom')}</span>
        </li>
        <li class="stack-item">
          <span class="stack-name">REST API Testing</span>
          <span class="stack-desc">{t('stack-api')}</span>
        </li>
      </ul>
    </div>
  </section>

  <footer>
    <div class="container">
      <div class="footer-inner">
        <span class="footer-copy">{t('footer-copy')}</span>
        <nav class="footer-links" aria-label="Footer links">
          <a href="https://www.linkedin.com/in/erikazambrano/" target="_blank" rel="noopener">LinkedIn</a>
          <a href="https://github.com/Erika-Zambrano" target="_blank" rel="noopener">GitHub</a>
        </nav>
      </div>
    </div>
  </footer>
</BaseLayout>

<style>
  .container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 24px;
  }

  header {
    background: var(--white);
    padding: 64px 0 48px;
    border-bottom: 1px solid var(--border);
  }

  header .container {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .header-name {
    font-family: var(--font-display);
    font-size: clamp(2rem, 6vw, 3rem);
    color: var(--heading);
    line-height: 1.15;
  }

  .header-role {
    font-size: 1rem;
    font-weight: 500;
    color: var(--accent);
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .header-links {
    display: flex;
    gap: 20px;
    margin-top: 12px;
    flex-wrap: wrap;
  }

  .header-links a { font-size: 0.9rem; color: var(--muted); }
  .header-links a:hover { color: var(--accent); text-decoration: none; }

  section {
    padding: 56px 0;
    border-bottom: 1px solid var(--border);
  }
  section:last-of-type { border-bottom: none; }

  .section-label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 16px;
  }

  .section-title {
    font-size: 1.35rem;
    font-weight: 600;
    color: var(--heading);
    margin-bottom: 16px;
  }

  p {
    font-size: 0.975rem;
    line-height: 1.75;
    color: var(--text);
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 16px;
    margin-top: 24px;
  }

  .card {
    background: var(--white);
    border-radius: 8px;
    box-shadow: var(--shadow);
    padding: 20px 24px;
  }

  .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 8px;
  }

  .card-title { font-size: 0.975rem; font-weight: 600; color: var(--heading); }
  .badges { display: flex; gap: 6px; }

  .badge {
    font-size: 0.72rem;
    font-weight: 500;
    padding: 2px 8px;
    border-radius: 99px;
  }

  .badge-type { background: #f0f0ee; color: #555; }
  .badge-tag  { background: var(--accent-light); color: var(--accent); }

  .card-file {
    font-family: 'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, monospace;
    font-size: 0.78rem;
    color: var(--muted);
    margin-top: 4px;
  }

  .ci-description { margin-bottom: 20px; }

  .ci-badge-row {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
    margin-top: 16px;
  }

  .stack-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-top: 20px;
  }

  .stack-item {
    display: flex;
    align-items: baseline;
    gap: 12px;
    font-size: 0.975rem;
  }

  .stack-item::before {
    content: '';
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    flex-shrink: 0;
    position: relative;
    top: -1px;
  }

  .stack-name { font-weight: 600; color: var(--heading); }
  .stack-desc { color: var(--muted); font-size: 0.875rem; }

  footer {
    padding: 32px 0;
    border-top: 1px solid var(--border);
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
  }

  .footer-copy { font-size: 0.85rem; color: var(--muted); }
  .footer-links { display: flex; gap: 16px; }
  .footer-links a { font-size: 0.85rem; color: var(--muted); }
  .footer-links a:hover { color: var(--accent); text-decoration: none; }

  @media (max-width: 600px) {
    section { padding: 40px 0; }
    .cards { grid-template-columns: 1fr; }
    .ci-badge-row { flex-direction: column; align-items: flex-start; }
  }
</style>
