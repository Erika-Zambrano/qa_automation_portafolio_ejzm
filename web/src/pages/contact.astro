---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLang, useTranslations } from '../i18n';

const lang = getLang(Astro.url.searchParams.get('lang') ?? undefined);
const t = useTranslations(lang);
---

<BaseLayout title={`${t('contact-label')} — Erika Zambrano`} activePage="contact">
  <div class="contact-wrapper">
    <p class="page-label">{t('contact-label')}</p>
    <h1 class="page-title">{t('contact-title')}</h1>
    <p class="page-desc">{t('contact-desc')}</p>

    <form class="contact-form" id="contact-form" action="https://api.web3forms.com/submit" method="POST" novalidate>
      <input type="hidden" name="access_key" value="57dcf9ff-73a7-4422-89f6-f57300e51b13" />
      <input type="hidden" name="subject" value={t('form-subject')} />
      <input type="hidden" name="redirect" value="false" />

      <div class="form-group">
        <label class="form-label" for="name">{t('form-label-name')}</label>
        <input class="form-input" type="text" id="name" name="name" required autocomplete="name"
          placeholder={t('form-placeholder-name') as string} />
        <span class="form-error" id="error-name" aria-live="polite"></span>
      </div>

      <div class="form-group">
        <label class="form-label" for="email">{t('form-label-email')}</label>
        <input class="form-input" type="email" id="email" name="email" required autocomplete="email"
          placeholder={t('form-placeholder-email') as string} />
        <span class="form-error" id="error-email" aria-live="polite"></span>
      </div>

      <div class="form-group">
        <label class="form-label" for="message">{t('form-label-message')}</label>
        <textarea class="form-input form-textarea" id="message" name="message" required rows="5"
          placeholder={t('form-placeholder-message') as string}></textarea>
        <span class="form-error" id="error-message" aria-live="polite"></span>
      </div>

      <button class="form-submit" type="submit" id="form-submit-btn">
        {t('form-submit')}
      </button>

      <p class="form-status" id="form-status" aria-live="polite"></p>
    </form>
  </div>
</BaseLayout>

<script>
  import { translations } from '../i18n/translations';
  import type { Lang } from '../i18n/translations';

  const lang = (document.documentElement.lang || 'es') as Lang;
  const t = (key: keyof typeof translations.es) => translations[lang][key] as string;

  function validateForm(): boolean {
    const name    = document.getElementById('name') as HTMLInputElement;
    const email   = document.getElementById('email') as HTMLInputElement;
    const message = document.getElementById('message') as HTMLTextAreaElement;
    let valid = true;

    function setError(field: HTMLElement, errorId: string, msg: string | null) {
      const el = document.getElementById(errorId)!;
      if (msg) {
        el.textContent = msg;
        field.classList.add('form-input--error');
        valid = false;
      } else {
        el.textContent = '';
        field.classList.remove('form-input--error');
      }
    }

    setError(name, 'error-name', name.value.trim() === '' ? t('field-error-name') : null);

    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    setError(email, 'error-email', !emailRegex.test(email.value.trim()) ? t('field-error-email') : null);

    setError(message, 'error-message', message.value.trim().length < 10 ? t('field-error-message') : null);

    return valid;
  }

  document.getElementById('contact-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form   = e.target as HTMLFormElement;
    const status = document.getElementById('form-status')!;
    const btn    = document.getElementById('form-submit-btn') as HTMLButtonElement;

    status.textContent = '';
    status.className = 'form-status';

    if (!validateForm()) return;

    btn.disabled = true;
    btn.textContent = t('form-sending');

    try {
      const res  = await fetch('https://api.web3forms.com/submit', { method: 'POST', body: new FormData(form) });
      const data = await res.json();

      if (data.success) {
        status.textContent = t('form-success');
        status.classList.add('form-status--success');
        form.reset();
        ['name', 'email', 'message'].forEach(id => {
          document.getElementById(id)?.classList.remove('form-input--error');
          const errEl = document.getElementById('error-' + id);
          if (errEl) errEl.textContent = '';
        });
      } else {
        throw new Error(data.message);
      }
    } catch {
      status.textContent = t('form-error');
      status.classList.add('form-status--error');
    } finally {
      btn.disabled = false;
      btn.textContent = t('form-submit');
    }
  });
</script>

<style>
  .contact-wrapper {
    max-width: 560px;
    margin: 0 auto;
    padding: 64px 24px 80px;
  }

  .page-label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 16px;
  }

  .page-title {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 4vw, 2rem);
    color: var(--heading);
    margin-bottom: 8px;
  }

  .page-desc {
    font-size: 0.975rem;
    color: var(--muted);
    margin: 0 0 32px;
  }

  .contact-form { display: flex; flex-direction: column; gap: 20px; }
  .form-group   { display: flex; flex-direction: column; gap: 6px; }

  .form-label { font-size: 0.875rem; font-weight: 500; color: var(--heading); }

  .form-input {
    font-family: var(--font-body);
    font-size: 0.975rem;
    color: var(--text);
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 10px 14px;
    transition: border-color 0.15s, box-shadow 0.15s;
    outline: none;
    width: 100%;
  }

  .form-input:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-light);
  }

  .form-textarea { resize: vertical; min-height: 120px; }

  .form-submit {
    font-family: var(--font-body);
    font-size: 0.925rem;
    font-weight: 600;
    color: var(--white);
    background: var(--accent);
    border: none;
    border-radius: 8px;
    padding: 12px 24px;
    cursor: pointer;
    transition: opacity 0.15s;
    align-self: flex-start;
  }

  .form-submit:hover    { opacity: 0.88; }
  .form-submit:disabled { opacity: 0.5; cursor: default; }

  .form-status { font-size: 0.9rem; min-height: 1.4em; }
  .form-status--success { color: var(--accent); }
  .form-status--error   { color: #c0392b; }

  :global(.form-input--error) {
    border-color: #c0392b !important;
    box-shadow: 0 0 0 3px rgba(192, 57, 43, 0.1) !important;
  }

  .form-error { font-size: 0.825rem; color: #c0392b; min-height: 1.2em; }
</style>
